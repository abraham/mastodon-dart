#!/bin/bash
set -e

CURRENT_SHA=$(jq -r '.sha' mastodon_openapi.json)
echo "Current SHA: $CURRENT_SHA"

LATEST_SHA=$(gh api repos/abraham/mastodon-openapi/commits/main --jq '.sha')
echo "Latest SHA: $LATEST_SHA"

if [ "$CURRENT_SHA" = "$LATEST_SHA" ]; then
  echo "SHA is up to date, no update needed"
  echo "sha_changed=false" >> $GITHUB_OUTPUT
else
  echo "SHA has changed, updating mastodon_openapi.json"
  jq --arg sha "$LATEST_SHA" '.sha = $sha' mastodon_openapi.json > mastodon_openapi.json.tmp
  mv mastodon_openapi.json.tmp mastodon_openapi.json
  echo "sha_changed=true" >> $GITHUB_OUTPUT
fi
